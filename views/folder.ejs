<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/styles.css">
  <title>Drive</title>
</head>
<body>

  <header class="topbar">
    <div class="topbar-logo">📁 <span>Drive</span></div>
    <div class="topbar-actions">
      <% if (locals.currentUser) { %>
        <span class="topbar-user"><%= currentUser.username %></span>
        <a href="/users/log-out" class="btn btn-ghost">Log out</a>
      <% } %>
    </div>
  </header>

  <div class="layout">
    <aside class="sidebar">
      <a href="/" class="sidebar-item">🏠 My Drive</a>
    </aside>

    <main class="main-content">
      <div class="breadcrumb">
        <a href="/">My Drive</a> / Folder
      </div>

      <div class="upload-bar">
        <form action="/data/upload" method="POST" enctype="multipart/form-data" style="display:flex;align-items:center;gap:12px">
          <input type="hidden" name="folderId" value="<%= folderId %>" />
          <input type="file" name="file" required />
          <button type="submit" class="btn btn-primary">Upload</button>
        </form>
      </div>

      <p class="section-title">Files</p>
      <% if (files.length === 0) { %>
        <p style="color:#9aa0a6;font-size:0.875rem">No files yet. Upload one above.</p>
      <% } else { %>
        <table class="file-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Size</th>
              <th>Uploaded</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% files.forEach((file) => { %>
              <tr>
                <td>📄 <%= file.name %></td>
                <td><%= (file.size / 1024).toFixed(1) %> KB</td>
                <td><%= new Date(file.uploadedAt).toLocaleDateString() %></td>
                <td>
                  <div class="file-actions">
                    <a href="/data/file/<%= file.id %>/download" class="btn btn-ghost btn-sm">⬇ Download</a>
                    <form action="/data/file/<%= file.id %>/delete" method="POST">
                      <button type="submit" class="btn btn-danger">🗑</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </main>
  </div>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/styles.css">
  <title>Members Only</title>
</head>
<body>
  <header>
    <h1>Members Only</h1>

    <% if (locals.currentUser) {%>
      <p>Welcome back, <%= currentUser.username %>.</p>

      <nav>
        <a href="/users/log-out">Log out</a>
      </nav>
      <form action="/data/folder" method="POST">
        <input type="text" name="name" placeholder="Folder name" required />
        <button type="submit">Create Folder</button>
      </form>
      <div class="folders">
        <% folders.forEach((folder) => { %>
  <a href="/data/folder/<%= folder.id %>"><%= folder.name %></a>

  <form action="/data/folder/<%= folder.id %>/update" method="POST" style="display:inline">
    <input type="text" name="name" placeholder="New name" required />
    <button type="submit">Rename</button>
  </form>

  <form action="/data/folder/<%= folder.id %>/delete" method="POST" style="display:inline">
    <button type="submit">Delete</button>
  </form>
<% }) %>
      </div>
    <% } else { %>
      <p>Please log in.</p>
    <% } %>
  </header>

  <main>
    <% if (!locals.currentUser) { %>
    <form action="/users/log-in" method="POST">
      <label for="username">Username</label>
      <input id="username" name="username" placeholder="username" type="text" />
      <label for="password">Password</label>
      <input id="password" name="password" type="password" />
      <button type="submit">Log In</button>
    </form>
    <p><a href="/users/sign-up">Create an account</a></p>
    <%}%>
  </main>
</body>
</html>

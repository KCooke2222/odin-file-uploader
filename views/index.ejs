<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/styles.css">
  <title>Drive</title>
</head>
<body>

  <header class="topbar">
    <div class="topbar-logo">📁 <span>Drive</span></div>
    <% if (locals.currentUser) { %>
      <div class="topbar-actions">
        <span class="topbar-user"><%= currentUser.username %></span>
        <a href="/users/log-out" class="btn btn-ghost">Log out</a>
      </div>
    <% } %>
  </header>

  <% if (locals.currentUser) { %>
    <div class="layout">
      <aside class="sidebar">
        <div class="sidebar-item active">🏠 My Drive</div>
      </aside>

      <main class="main-content">
        <div class="new-folder-bar">
          <form action="/data/folder" method="POST" style="display:flex;gap:8px">
            <input type="text" name="name" placeholder="New folder name" required />
            <button type="submit" class="btn btn-primary">+ New Folder</button>
          </form>
        </div>

        <p class="section-title">Folders</p>
        <div class="folder-grid">
          <% folders.forEach((folder) => { %>
            <div class="folder-card">
              <span class="folder-icon">📂</span>
              <a href="/data/folder/<%= folder.id %>" class="folder-name"><%= folder.name %></a>
              <div class="folder-actions">
                <form class="rename-form" action="/data/folder/<%= folder.id %>/update" method="POST" style="display:flex;gap:4px">
                  <input type="text" name="name" placeholder="Rename" required />
                  <button type="submit" class="btn btn-ghost btn-sm">✏️</button>
                </form>
                <form action="/data/folder/<%= folder.id %>/delete" method="POST">
                  <button type="submit" class="btn btn-danger">🗑</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </main>
    </div>

  <% } else { %>
    <div class="auth-container">
      <div class="auth-card">
        <h1>Sign in to Drive</h1>
        <form action="/users/log-in" method="POST">
          <div class="form-group">
            <label for="username">Username</label>
            <input id="username" name="username" type="text" placeholder="Username" />
          </div>
          <div class="form-group">
            <label for="password">Password</label>
            <input id="password" name="password" type="password" placeholder="Password" />
          </div>
          <button type="submit" class="btn btn-primary">Sign In</button>
        </form>
        <div class="auth-footer">
          No account? <a href="/users/sign-up">Sign up</a>
        </div>
      </div>
    </div>
  <% } %>

</body>
</html>
